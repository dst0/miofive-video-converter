{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Miofive Video Converter",
  "version": "1.0.0",
  "identifier": "com.dst.miofive-video-converter",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run build:sidecar:demo",
    "beforeBuildCommand": "npm run build:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "Miofive Video Converter",
        "label": "main",
        "url": "index.html",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Video",
    "resources": ["resources/**/*"],
    "externalBin": ["binaries/miofive-server"],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
