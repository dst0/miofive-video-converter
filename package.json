{
  "name": "miofive-video-converter",
  "version": "1.0.0",
  "description": "Scan and export precise Miofive DashCam MP4 video ranges by timestamp",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build:ffmpeg": "scripts/build-ffmpeg-macos-arm64.sh",
    "copy:ffmpeg": "node scripts/copy-ffmpeg-binaries.js",
    "build:sidecar": "npm run copy:ffmpeg && node scripts/build-sidecar.js",
    "desktop": "tauri dev",
    "build:mac": "npm run dist:mac",
    "install:mac": "mkdir -p \"$HOME/Applications\" && rm -rf \"$HOME/Applications/Miofive Video Converter.app\" && cp -R \"src-tauri/target/release/bundle/macos/Miofive Video Converter.app\" \"$HOME/Applications/\"",
    "pack:mac": "tauri build --bundles app",
    "dist:mac": "tauri build --bundles dmg,app",
    "check:licenses": "node scripts/check-open-source-licenses.js",
    "postinstall": "node install-ffmpeg.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "keywords": [
    "video",
    "mp4",
    "export",
    "ffmpeg"
  ],
  "author": "dst",
  "license": "MIT",
  "pkg": {
    "assets": [
      "public/**/*",
      "test-data/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2.9.1",
    "@yao-pkg/pkg": "6.12.0"
  }
}
